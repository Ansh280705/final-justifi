generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================
// USER MODEL
// ==========================
model User {
  id          String   @id @default(uuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  phone       String? // Added phone number for WhatsApp
  imageUrl    String?
  role        UserRole @default(UNASSIGNED)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  credits Int @default(0) // Client credits

  // Lawyer-specific fields
  practiceArea       String?
  experience         Int?
  credentialUrl      String?
  description        String?             @db.Text
  verificationStatus VerificationStatus? @default(PENDING)
  qualifications     String[] // ["LLB", "LLM"]

  // Relations
  clientCases     LegalCase[]              @relation("ClientCases")
  lawyerCases     LegalCase[]              @relation("LawyerCases")
  availabilities  Availability[]
  transactions    CreditTransaction[]
  payouts         Payout[]
  paymentRequests PaymentRequest[]

  // Emergency / SOS Fields
  emergencyEmails String[] // Family & Friends contact list
  emergencyAlerts EmergencyAlert[]

  // Dispute relations
  disputes Dispute[]
}

model EmergencyAlert {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude  Float?
  longitude Float?
  status    EmergencyStatus @default(ACTIVE)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId, status])
}

enum EmergencyStatus {
  ACTIVE
  RESOLVED
}

// ==========================
// ENUMS
// ==========================
enum UserRole {
  UNASSIGNED
  CLIENT
  LAWYER
  ADMIN
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum SlotStatus {
  AVAILABLE
  BOOKED
  BLOCKED
}

enum CaseStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum DisputeStatus {
  INTAKE
  ANALYZED
  NOTICE_GENERATED
  NOTICE_SENT
  MEDIATION
  RESOLVED
  ESCALATED_INTERN
  ESCALATED_SENIOR
  CLOSED
}

enum TransactionType {
  CREDIT_PURCHASE
  CASE_DEDUCTION
  ADMIN_ADJUSTMENT
}

enum PayoutStatus {
  PROCESSING
  PROCESSED
}

// ==========================
// AVAILABILITY MODEL
// ==========================
model Availability {
  id        String     @id @default(uuid())
  lawyerId  String
  lawyer    User       @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  startTime DateTime
  endTime   DateTime
  status    SlotStatus @default(AVAILABLE)

  @@index([lawyerId, startTime])
}

// ==========================
// LEGALCASE MODEL (Formerly Appointment)
// ==========================
model LegalCase {
  id                 String            @id @default(uuid())
  clientId           String
  client             User              @relation("ClientCases", fields: [clientId], references: [id])
  lawyerId           String
  lawyer             User              @relation("LawyerCases", fields: [lawyerId], references: [id])
  startTime          DateTime
  endTime            DateTime
  status             CaseStatus        @default(SCHEDULED)
  notes              String?           @db.Text
  clientDescription  String?           @db.Text
  legalAdvice        LegalAdvice?

  clientName   String
  clientPhone  String
  clientAge    Int
  clientGender String

  // Video session fields
  videoSessionId    String?
  videoSessionToken String? // optional, useful for debugging

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startTime])
  @@index([lawyerId, startTime])
}

// ==========================
// CREDIT TRANSACTION
// ==========================
model CreditTransaction {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int
  type          TransactionType
  packageId     String?
  transactionId String?         @unique // Added unique transaction ID for tracking
  createdAt     DateTime        @default(now())
}

// ==========================
// PAYOUT MODEL
// ==========================
model Payout {
  id                String       @id @default(uuid())
  lawyerId          String
  lawyer            User         @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  amount            Float
  credits           Int
  platformFee       Float
  netAmount         Float
  paypalEmail       String
  // Optional payment reference for Razorpay
  razorpayPaymentId String?
  status            PayoutStatus @default(PROCESSING)
  paymentId         String? // Added field for payment reference
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @default(now()) @updatedAt
  processedAt       DateTime?
  processedBy       String?

  @@index([status, createdAt])
  @@index([lawyerId, status])
}

// ==========================
// BLOG & CATEGORY MODELS
// ==========================
model Blog {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  imageUrl    String?
  isPublished Boolean   @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  likes       Int       @default(0)
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  blogs Blog[]
}

// ==========================
// LAWFIRM MODEL
// ==========================
model LawFirm {
  id        String   @id @default(uuid())
  name      String
  address   String
  phone     String?
  rating    Float    @default(0)
  reviews   Int      @default(0)
  timings   String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LegalAdvice {
  id             String    @id @default(cuid())
  caseId         String    @unique
  lawyerId       String
  clientId       String
  caseHistory    String?   @db.Text
  caseSummary    String?
  legalPoints    String
  instructions   String?
  followUpDate   DateTime?

  createdAt DateTime @default(now())

  case LegalCase @relation(fields: [caseId], references: [id])
}

// ==========================
// PAYMENT REQUEST MODEL
// ==========================
enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

model PaymentRequest {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  credits       Int
  screenshotUrl String
  status        PaymentStatus @default(PENDING)
  transactionId String?
  paymentMethod String?
  packageId     String?
  isNotified     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  processedAt   DateTime?
  processedBy   String?
}

// ==========================
// NEWS & BANNERS MODEL
// ==========================
model News {
  id        String   @id @default(uuid())
  title     String
  content   String?  @db.Text
  imageUrl  String?
  link      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================
// OFFLINE CLINIC MODEL (Renamed to OfflineOffice)
// ==========================
model OfflineOffice {
  id          String   @id @default(uuid())
  name        String
  lawyerName  String
  practiceArea String
  phone       String
  email       String?
  address     String   @db.Text
  city        String
  state       String
  pincode     String
  latitude    Float
  longitude   Float
  timing      String   // e.g. "Mon-Sat, 9am-6pm"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([isActive])
}

// ==========================
// DISPUTE MODEL
// ==========================
model Dispute {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Complainant Info
  complainantName  String
  complainantEmail String
  complainantPhone String

  // Opponent Info
  opponentName     String?
  opponentEmail    String?

  // Dispute Details
  category         String
  description      String         @db.Text
  aiQuestions      Json?          // [{q: "...", a: "..."}]
  aiAnalysis       String?        @db.Text
  legalNotice      String?        @db.Text

  // Scheduling
  meetLink         String?
  preferredDate    DateTime?
  preferredTime    String?

  // Resolution
  status           DisputeStatus  @default(INTAKE)
  userResolved     Boolean        @default(false)
  opponentResolved Boolean        @default(false)

  // Escalation
  internId         String?
  seniorLawyerId   String?
  escalationNotes  String?        @db.Text

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}
